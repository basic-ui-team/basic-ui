{
  "name": "@basic-ui/tokens",
  "version": "0.2.0",
  "description": "Design tokens and theming system for basic-ui",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles/theme.css": "./dist/styles/theme.css",
    "./presets": {
      "import": "./dist/presets/index.js",
      "types": "./dist/presets/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/generate-theme-css.ts",
    "build": "pnpm generate && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.1"
  }
}
