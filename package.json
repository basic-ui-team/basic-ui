{
  "name": "basic-ui-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "basic-ui: An accessible, extensible component library for React",
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0",
    "npm": ">=9.0.0",
    "yarn": ">=3.6.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:core": "turbo build --filter=@basic-ui/core",
    "build:tokens": "turbo build --filter=@basic-ui/tokens",
    "build:icons": "turbo build --filter=@basic-ui/icons",
    "generate": "pnpm --filter @basic-ui/tokens generate",
    "storybook": "turbo dev --filter=@basic-ui/storybook",
    "storybook:build": "turbo build --filter=@basic-ui/storybook",
    "lint": "turbo lint",
    "typecheck": "turbo type-check",
    "format": "turbo format",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "test:ui": "turbo test -- --ui"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.3.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    }
  }
}
